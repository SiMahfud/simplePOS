<!DOCTYPE html>
<html lang="en" data-bs-theme="<%= locals.settings.theme || 'light' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kasir - Arumi POS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
    <style>
        #reader {
            width: 100%;
            border-radius: 8px;
            background-color: #000;
        }
        .cart-item-img {
            width: 50px;
            height: 50px;
            object-fit: cover;
            border-radius: 5px;
        }
        #scan-result {
            height: 50px;
        }
        #search-results {
            position: absolute;
            width: calc(100% - 2rem);
            z-index: 1000;
        }
        .search-result-item {
            cursor: pointer;
        }
        .search-result-item:hover {
            background-color: #e9ecef;
        }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">
    <%- include('_navbar', { user: user, active: 'cashier' }) %>

    <div class="container-fluid mt-4">
        <% if (typeof lowStockProducts !== 'undefined' && lowStockProducts.length > 0) { %>
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <strong><i class="bi bi-exclamation-triangle-fill"></i> Stok Segera Habis!</strong>
            <ul class="mb-0 mt-2">
                <% lowStockProducts.forEach(product => { %>
                    <li><%= product.name %> (Sisa: <strong><%= product.stock %></strong>)</li>
                <% }) %>
            </ul>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
        <% } %>

        <div class="row">
            <!-- Left Column -->
            <div class="col-md-5">
                <!-- Search Section -->
                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title">Cari Produk</h5>
                        <div class="position-relative">
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-search"></i></span>
                                <input type="text" id="product-search" class="form-control" placeholder="Ketik nama produk...">
                            </div>
                            <div id="search-results" class="list-group mt-1"></div>
                        </div>
                    </div>
                </div>

                <!-- Scanner Section -->
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Pemindai Barcode/QR</h5>
                        <div id="reader" class="mb-3"></div>
                        <div class="d-grid gap-2">
                            <button id="startScanBtn" class="btn btn-success"><i class="bi bi-camera-video"></i> Mulai Scan</button>
                            <button id="stopScanBtn" class="btn btn-danger" style="display: none;"><i class="bi bi-stop-circle"></i> Hentikan Scan</button>
                        </div>
                        <div id="scan-result" class="mt-3 alert" role="alert" style="display: none;"></div>
                    </div>
                </div>
            </div>

            <!-- Cart Section (Right) -->
            <div class="col-md-7">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Keranjang Belanja</h5>
                        <div class="table-responsive">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Produk</th>
                                        <th>Harga</th>
                                        <th style="width: 130px;">Jumlah</th>
                                        <th>Subtotal</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody id="cart-items">
                                    <!-- Cart items will be injected here -->
                                </tbody>
                            </table>
                        </div>
                        <div id="cart-placeholder" class="text-center p-5 text-muted">
                            <i class="bi bi-cart-x" style="font-size: 3rem;"></i>
                            <p class="mt-2">Keranjang kosong. Silakan scan atau cari produk.</p>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-end align-items-center">
                            <h4 class="me-4">Total:</h4>
                            <h4 id="cart-total" class="fw-bold">Rp 0</h4>
                        </div>
                        <div class="d-grid mt-3">
                            <button id="completeTransactionBtn" class="btn btn-primary btn-lg" disabled>Selesaikan Transaksi</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // --- STATE --- 
            const cart = [];
            let isProcessingScan = false;

            // --- DOM ELEMENTS ---
            const scanResultDiv = document.getElementById('scan-result');
            const cartItemsTbody = document.getElementById('cart-items');
            const cartTotalEl = document.getElementById('cart-total');
            const cartPlaceholder = document.getElementById('cart-placeholder');
            const completeTransactionBtn = document.getElementById('completeTransactionBtn');
            const searchInput = document.getElementById('product-search');
            const searchResultsContainer = document.getElementById('search-results');

            // --- SCANNER --- 
            const html5QrCode = new Html5Qrcode("reader");
            const startScanBtn = document.getElementById('startScanBtn');
            const stopScanBtn = document.getElementById('stopScanBtn');

            const onScanSuccess = (decodedText, decodedResult) => {
                if (isProcessingScan) return; // Prevent double scans
                isProcessingScan = true;

                showScanResult(`Mencari produk dengan SKU: ${decodedText}...`, 'alert-info');
                
                fetch(`/api/products/sku/${decodedText}`)
                    .then(response => {
                        if (!response.ok) return response.json().then(err => { throw new Error(err.error || 'Produk tidak ditemukan') });
                        return response.json();
                    })
                    .then(product => {
                        showScanResult(`Produk ditemukan: ${product.name}`, 'alert-success');
                        addToCart(product);
                        stopScanner();
                    })
                    .catch(error => showScanResult(error.message, 'alert-danger'))
                    .finally(() => {
                        // Reset flag after a short delay to allow scanner to fully stop and prevent immediate re-scans
                        setTimeout(() => { isProcessingScan = false; }, 1000);
                    });
            };

            const startScanner = () => {
                html5QrCode.start({ facingMode: "environment" }, { fps: 10, qrbox: { width: 250, height: 150 } }, onScanSuccess, (error) => { /* ignore */ })
                    .then(() => {
                        startScanBtn.style.display = 'none';
                        stopScanBtn.style.display = 'block';
                    }).catch(err => alert("Gagal memulai scanner. Pastikan Anda memberikan izin kamera."));
            };

            const stopScanner = () => {
                if (html5QrCode && html5QrCode.isScanning) {
                    html5QrCode.stop().then(() => {
                        startScanBtn.style.display = 'block';
                        stopScanBtn.style.display = 'none';
                    });
                }
            };

            // --- UTILITIES ---
            const showScanResult = (message, type) => {
                scanResultDiv.textContent = message;
                scanResultDiv.className = `mt-3 alert ${type}`;
                scanResultDiv.style.display = 'block';
                setTimeout(() => { scanResultDiv.style.display = 'none'; }, 3000);
            };

            const debounce = (func, delay) => {
                let timeout;
                return function(...args) {
                    clearTimeout(timeout);
                    timeout = setTimeout(() => func.apply(this, args), delay);
                };
            };

            // --- CART LOGIC ---
            const addToCart = (product) => {
                const existingItem = cart.find(item => item.id === product.id);
                if (existingItem) {
                    if(existingItem.quantity < product.stock) existingItem.quantity++;
                    else showScanResult(`Stok produk ${product.name} tidak mencukupi.`, 'alert-warning');
                } else {
                     if(product.stock > 0) cart.push({ ...product, quantity: 1 });
                     else showScanResult(`Stok produk ${product.name} habis.`, 'alert-warning');
                }
                renderCart();
            };

            const updateQuantity = (productId, newQuantity) => {
                const item = cart.find(item => item.id === productId);
                if (item) {
                    if (newQuantity > 0 && newQuantity <= item.stock) {
                        item.quantity = newQuantity;
                    } else if (newQuantity > item.stock) {
                        showScanResult(`Stok produk ${item.name} hanya tersisa ${item.stock}.`, 'alert-warning');
                    } else if (newQuantity <= 0) {
                        removeFromCart(productId);
                    }
                }
                renderCart();
            };

            const removeFromCart = (productId) => {
                const itemIndex = cart.findIndex(item => item.id === productId);
                if (itemIndex > -1) cart.splice(itemIndex, 1);
                renderCart();
            };

            const renderCart = () => {
                cartItemsTbody.innerHTML = '';
                let total = 0;

                if (cart.length === 0) {
                    cartPlaceholder.style.display = 'block';
                    completeTransactionBtn.disabled = true;
                } else {
                    cartPlaceholder.style.display = 'none';
                    completeTransactionBtn.disabled = false;
                    cart.forEach(item => {
                        const subtotal = item.price * item.quantity;
                        total += subtotal;
                        const tr = document.createElement('tr');
                        tr.innerHTML = `
                            <td><div class="d-flex align-items-center"><img src="${item.image_url || 'https://placehold.co/400x300/f8f9fa/6c757d?text=No+Image'}" class="cart-item-img me-2" alt="${item.name}"> <div>${item.name}</div></div></td>
                            <td>Rp ${item.price.toLocaleString('id-ID')}</td>
                            <td><div class="input-group"><button class="btn btn-outline-secondary btn-sm" onclick="window.updateQuantity(${item.id}, ${item.quantity - 1})">-</button><input type="text" class="form-control form-control-sm text-center" value="${item.quantity}" onchange="window.updateQuantity(${item.id}, parseInt(this.value))" ><button class="btn btn-outline-secondary btn-sm" onclick="window.updateQuantity(${item.id}, ${item.quantity + 1})">+</button></div></td>
                            <td class="fw-bold">Rp ${subtotal.toLocaleString('id-ID')}</td>
                            <td><button class="btn btn-danger btn-sm" onclick="window.removeFromCart(${item.id})"><i class="bi bi-x-circle"></i></button></td>
                        `;
                        cartItemsTbody.appendChild(tr);
                    });
                }
                cartTotalEl.textContent = `Rp ${total.toLocaleString('id-ID')}`;
            };

            // --- SEARCH LOGIC ---
            const handleSearch = (query) => {
                if (query.length < 2) {
                    searchResultsContainer.innerHTML = '';
                    return;
                }
                fetch(`/api/products/search?q=${encodeURIComponent(query)}`)
                    .then(res => res.json())
                    .then(products => {
                        searchResultsContainer.innerHTML = '';
                        if (products.length > 0) {
                            products.forEach(product => {
                                const item = document.createElement('a');
                                item.href = '#';
                                item.className = 'list-group-item list-group-item-action search-result-item';
                                item.innerHTML = `
                                    <div class="d-flex w-100 justify-content-between">
                                        <h6 class="mb-1">${product.name}</h6>
                                        <small>Stok: ${product.stock}</small>
                                    </div>
                                    <p class="mb-1">Rp ${product.price.toLocaleString('id-ID')}</p>
                                `;
                                item.addEventListener('click', (e) => {
                                    e.preventDefault();
                                    addToCart(product);
                                    searchInput.value = '';
                                    searchResultsContainer.innerHTML = '';
                                });
                                searchResultsContainer.appendChild(item);
                            });
                        } else {
                            searchResultsContainer.innerHTML = '<div class="list-group-item">Produk tidak ditemukan</div>';
                        }
                    });
            };

            // --- EVENT LISTENERS ---
            window.updateQuantity = updateQuantity;
            window.removeFromCart = removeFromCart;
            startScanBtn.addEventListener('click', startScanner);
            stopScanBtn.addEventListener('click', stopScanner);
            searchInput.addEventListener('input', debounce(e => handleSearch(e.target.value), 300));
            document.addEventListener('click', (e) => {
                if (!searchResultsContainer.contains(e.target)) {
                    searchResultsContainer.innerHTML = '';
                }
            });

            completeTransactionBtn.addEventListener('click', () => {
                const total = cart.reduce((sum, item) => sum + item.price * item.quantity, 0);
                if (cart.length === 0) return alert("Keranjang masih kosong.");

                completeTransactionBtn.disabled = true;
                completeTransactionBtn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Memproses...';

                fetch('/transactions/create', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ cart, total }) })
                    .then(response => {
                        if (!response.ok) return response.json().then(err => { throw new Error(err.error || 'Gagal menyimpan transaksi.') });
                        return response.json();
                    })
                    .then(data => {
                        alert(`Transaksi berhasil disimpan dengan ID: ${data.transactionId}`);
                        cart.length = 0;
                        renderCart();
                    })
                    .catch(error => alert(`Error: ${error.message}`))
                    .finally(() => {
                        completeTransactionBtn.disabled = false;
                        completeTransactionBtn.innerHTML = 'Selesaikan Transaksi';
                    });
            });
            
            renderCart(); // Initial render
        });
    </script>
    <%- include('_footer') %>
</body>
</html>