<!DOCTYPE html>
<html lang="en" data-bs-theme="<%= locals.settings.theme || 'light' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Transaction Detail</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        body {
            background-color: var(--bs-body-bg);
        }
        .invoice-container {
            max-width: 800px;
            margin: 2rem auto;
            background-color: var(--bs-tertiary-bg);
            padding: 2rem;
            border-radius: 15px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }
        .invoice-header h1 {
            color: var(--bs-body-color);
        }
        [data-bs-theme="dark"] .table-striped > tbody > tr:nth-of-type(odd) > * {
            --bs-table-accent-bg: var(--bs-tertiary-bg);
        }
        .invoice-details, .transaction-details {
            margin-bottom: 2rem;
        }
        .invoice-details p, .transaction-details p {
            margin-bottom: 0.5rem;
        }
        .invoice-details strong, .transaction-details strong {
        }
        .items-table th {
        }
        .total-section {
            text-align: right;
            margin-top: 2rem;
        }
        .total-section p {
            font-size: 1.2rem;
            font-weight: bold;
        }
        .total-section .grand-total {
            font-size: 1.5rem;
            color: #28a745;
        }
        .footer-actions {
            text-align: center;
            margin-top: 2rem;
        }

        /* Thermal Receipt Styles */
        #thermal-receipt {
            display: none; /* Hidden by default */
            width: 302px; /* 58mm paper width is approx 2.28 inches, plus some padding */
            font-family: 'Courier New', Courier, monospace;
            font-size: 12px;
            color: #000;
            padding: 10px;
            border: 1px solid #ccc;
        }
        #thermal-receipt h5 {
            text-align: center;
            margin: 0;
            font-size: 14px;
            font-weight: bold;
        }
        #thermal-receipt p {
            margin: 2px 0;
        }
        #thermal-receipt .meta-info {
            font-size: 10px;
            text-align: center;
            margin-bottom: 10px;
        }
        #thermal-receipt table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }
        #thermal-receipt th, #thermal-receipt td {
            padding: 2px;
            text-align: left;
        }
        #thermal-receipt .item-col {
            width: 150px;
        }
        #thermal-receipt .qty-col, #thermal-receipt .price-col {
            width: 50px;
            text-align: right;
        }
        #thermal-receipt .total-row td {
            border-top: 1px dashed #000;
            font-weight: bold;
            padding-top: 5px;
        }
        #thermal-receipt .footer {
            text-align: center;
            margin-top: 10px;
            font-size: 10px;
        }

        /* Print-specific styles */
        @media print {
            body * {
                visibility: hidden;
            }
            #thermal-receipt, #thermal-receipt * {
                visibility: visible;
            }
            #thermal-receipt {
                display: block;
                position: absolute;
                left: 0;
                top: 0;
                width: 100%; /* Use full printable area */
                font-size: 10pt; /* Adjust font size for printers */
                border: none;
            }
             #thermal-receipt h5 { font-size: 12pt; }
             #thermal-receipt p { font-size: 9pt; }
             #thermal-receipt .meta-info { font-size: 8pt; }
             #thermal-receipt table { font-size: 9pt; }
        }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">
    <%- include('_navbar', { user: user, active: 'transactions' }) %>

    <div class="container" id="ui-view">
        <div class="invoice-container">
            <div class="invoice-header">
                <h1><i class="bi bi-receipt-cutoff"></i> Transaction Detail</h1>
                <p class="text-muted">Details for transaction #<%= transaction.id %></p>
            </div>

            <div class="row transaction-details">
                <div class="col-md-6">
                    <p><strong>Transaction ID:</strong> <%= transaction.id %></p>
                    <p><strong>Date:</strong> <%= new Date(transaction.timestamp).toLocaleDateString('id-ID', { timeZone: 'Asia/Jakarta' }) %></p>
                    <p><strong>Time:</strong> <%= new Date(transaction.timestamp).toLocaleTimeString('id-ID', { timeZone: 'Asia/Jakarta' }) %></p>
                </div>
                <div class="col-md-6 text-md-end">
                    <p><strong>Status:</strong> <span class="badge bg-success">Completed</span></p>
                </div>
            </div>

            <h5 class="mt-4 mb-3"><i class="bi bi-cart3"></i> Items Purchased</h5>
            <div class="table-responsive">
                <table class="table table-striped table-bordered items-table">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>Product</th>
                            <th>Quantity</th>
                            <th>Price per Item</th>
                            <th>Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% transaction.items.forEach((item, index) => { %>
                            <tr>
                                <td><%= index + 1 %></td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <% if (item.image_url) { %>
                                            <img src="<%= item.image_url %>" alt="<%= item.name %>" width="40" class="me-2 rounded">
                                        <% } %>
                                        <span><%= item.name %></span>
                                    </div>
                                </td>
                                <td><%= item.quantity %></td>
                                <td>Rp <%= item.price_per_item.toLocaleString('id-ID') %></td>
                                <td>Rp <%= (item.quantity * item.price_per_item).toLocaleString('id-ID') %></td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>

            <div class="total-section">
                <p>Total: <span class="grand-total">Rp <%= transaction.total_amount.toLocaleString('id-ID') %></span></p>
            </div>

            <div class="footer-actions">
                <a href="/transactions" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back to Transactions</a>
                <button class="btn btn-primary" onclick="printBluetooth()"><i class="bi bi-printer"></i> Print Struk</button>
            </div>
        </div>
    </div>

    <!-- Thermal Receipt Structure (Hidden) -->
    <div id="thermal-receipt">
        <h5>Arumi Store</h5>
        <p style="text-align: center;">Jl. Merdeka No. 123, Jakarta</p>
        <div class="meta-info">
            <div>ID: <%= transaction.id %></div>
            <div>Tanggal: <%= new Date(transaction.timestamp).toLocaleString('id-ID', { timeZone: 'Asia/Jakarta' }) %></div>
            <div>Kasir: <%= user.username %></div>
        </div>
        <p>------------------------------</p>
        <table>
            <% transaction.items.forEach(item => { %>
                <tr>
                    <td colspan="3"><%= item.name %></td>
                </tr>
                <tr>
                    <td><%= item.quantity %> x</td>
                    <td style="text-align: right;">@<%= item.price_per_item.toLocaleString('id-ID') %></td>
                    <td style="text-align: right;"><%= (item.quantity * item.price_per_item).toLocaleString('id-ID') %></td>
                </tr>
            <% }); %>
        </table>
        <p>------------------------------</p>
        <table>
            <tr class="total-row">
                <td>Total</td>
                <td style="text-align: right;">Rp <%= transaction.total_amount.toLocaleString('id-ID') %></td>
            </tr>
        </table>
        <p>------------------------------</p>
        <div class="footer">
            <p>Terima kasih telah berbelanja!</p>
        </div>
    </div>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        async function printBluetooth() {
            const S_INIT = "\x1B\x40";
            const S_ALIGN_CT = "\x1B\x61\x01";
            const S_ALIGN_LT = "\x1B\x61\x00";
            const S_TXT_NORMAL = "\x1D\x21\x00";
            const S_TXT_2HEIGHT = "\x1D\x21\x01";
            const S_TXT_2WIDTH = "\x1D\x21\x10";
            const S_TXT_4SQUARE = "\x1D\x21\x11";
            const S_CUT_FULL = "\x1D\x56\x00";

            let receipt = "";
            receipt += S_INIT;
            receipt += S_ALIGN_CT;
            receipt += S_TXT_2HEIGHT;
            receipt += "Arumi Store\n";
            receipt += S_TXT_NORMAL;
            receipt += "Jl. Merdeka No. 123, Jakarta\n";
            receipt += `ID: <%= transaction.id %>\n`;
            receipt += `Tanggal: <%= new Date(transaction.timestamp).toLocaleString('id-ID', { timeZone: 'Asia/Jakarta' }) %>\n`;
            receipt += `Kasir: <%= user.username %>\n`;
            receipt += "--------------------------------\n";

            <% transaction.items.forEach(item => { %>
            receipt += `${S_ALIGN_LT}${S_TXT_NORMAL}<%= item.name %>\n`;
            receipt += `${S_ALIGN_LT}${S_TXT_NORMAL}<%= item.quantity %> x @<%= item.price_per_item.toLocaleString('id-ID') %>\t`;
            receipt += `<%= (item.quantity * item.price_per_item).toLocaleString('id-ID') %>\n`;
            <% }); %>

            receipt += "--------------------------------\n";
            receipt += `${S_ALIGN_LT}${S_TXT_NORMAL}Total\tRp <%= transaction.total_amount.toLocaleString('id-ID') %>\n`;
            receipt += "--------------------------------\n";
            receipt += `${S_ALIGN_CT}${S_TXT_NORMAL}Terima kasih telah berbelanja!\n`;
            receipt += S_CUT_FULL;

            try {
                const device = await navigator.bluetooth.requestDevice({
                    filters: [{ services: ['000018f0-0000-1000-8000-00805f9b34fb'] }]
                });

                const server = await device.gatt.connect();
                const service = await server.getPrimaryService('000018f0-0000-1000-8000-00805f9b34fb');
                const characteristic = await service.getCharacteristic('00002af1-0000-1000-8000-00805f9b34fb');

                const encoder = new TextEncoder();
                const data = encoder.encode(receipt);

                await characteristic.writeValue(data);
                alert('Printing...');
            } catch (error) {
                console.error('Bluetooth printing error:', error);
                alert('Error connecting to Bluetooth printer.');
            }
        }
    </script>
    <%- include('_footer') %>
</body>
</html>
